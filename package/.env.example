# openclaw-gmail-triage — copy to e.g. ~/.openclaw/gmail.env
# Scripts auto-source $OPENCLAW_HOME/gmail.env (or GMAIL_ENV_FILE) when present.
# Replace every placeholder before running. No secrets belong in this file in git.

# --- Paths ---
# OPENCLAW_HOME=$HOME/.openclaw
# GMAIL_CREDS_DIR=$HOME/.gmail-mcp
# OPENCLAW_BIN=$OPENCLAW_HOME/bin
# OPENCLAW_SECRETS=$OPENCLAW_HOME/secrets.json
# GMAIL_ENV_FILE=$OPENCLAW_HOME/gmail.env

# --- Index / RAG (required) ---
# Point at your Chroma, embedder, and retrieve services (any reachable host).
CHROMA_URL=http://chroma.example:8000
GMAIL_EMBED_URL=http://embedder.example:8091/v1/embeddings
GMAIL_RETRIEVE_URL=http://retrieve.example:8100/retrieve
# GMAIL_EMBED_MODEL=nomic-embed-text-v1.5
GMAIL_CHROMA_COLLECTION=gmail_inbox

# --- Agent / labels ---
GMAIL_AGENT_ID=gmail-triage
GMAIL_LABEL_PREFIX=OC

# --- Slack (required for triage/e2e deliver) ---
GMAIL_SLACK_CHANNEL=YOUR_SLACK_CHANNEL_ID
# GMAIL_ALERT_SLACK_CHANNEL=YOUR_ALERT_CHANNEL_ID

# --- Slack Interactivity (digest Approve button; HTTP endpoint, not Socket Mode) ---
# Slack app → Interactivity On → Request URL → public URL that proxies to this host:8787/slack/interact
# Signing secret: set here OR in secrets.json → providers.slack.signingSecret (do not commit secrets)
# GMAIL_SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET
# Fail-closed: empty allowlist denies all Approve clicks
# GMAIL_SLACK_APPROVE_USERS=U01234567,U89ABCDEF
# GMAIL_SLACK_INTERACT_HOST=127.0.0.1
# GMAIL_SLACK_INTERACT_PORT=8787
# GMAIL_UNSUB_BATCH_TTL_DAYS=7

# --- Triage knobs ---
# GMAIL_TRIAGE_TOTAL=50
# GMAIL_TRIAGE_CHUNK=25
# GMAIL_TRIAGE_MAX_ITEMS=25
# GMAIL_TRIAGE_TZ=America/New_York
# GMAIL_SYNC_LOOKBACK_DAYS=2
# GMAIL_SYNC_MAX_EMAILS=80
# GMAIL_PRUNE_KEEP_DAYS=90
# GMAIL_MARK_NEWSLETTER_READ=1
# GMAIL_MARK_SOCIAL_READ=1
# GMAIL_MARK_SPAM_READ=1

# --- Post-unsub recidivism (watch → SPAM) ---
# After successful approve, sender is watched. Past grace, finalize forces SPAM.
# GMAIL_POST_UNSUB_WATCH=1
# GMAIL_POST_UNSUB_GRACE_DAYS=3
# GMAIL_POST_UNSUB_SCOPE=email
# GMAIL_POST_UNSUB_DOMAIN_AFTER_HITS=2
# GMAIL_MARK_POST_UNSUB_SPAM_READ=1
